# Copy to .env and fill in real values: cp .env.example .env

# Public site URL (no trailing slash) — used for canonical links, OG images, sitemap
NEXT_PUBLIC_SITE_URL="https://your-production-domain.com"

# Use Railway public URL for local dev if you don't run Postgres locally
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/railway?schema=public"
ADMIN_SECRET="change-me-to-a-long-random-string"

OTP_TTL_MINUTES=10
OTP_MAX_REQUESTS_PER_HOUR=5

# Resend — https://resend.com/api-keys
RESEND_API_KEY="re_your_api_key"
# Plain address or display name + angle brackets — not a bare domain
RESEND_FROM="MetaboliQ OS <noreply@yourdomain.com>"

# Optional: weekly cron at POST /api/cron/weekly
CRON_SECRET="your-long-random-secret"
