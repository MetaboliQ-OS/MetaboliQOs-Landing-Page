generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Holds form + OTP until email is verified. Deleted after successful registration.
model PendingSignup {
  id                String    @id @default(cuid())
  email             String    @unique
  firstName         String
  lastName          String
  country           String?
  primaryInterest   String?
  whatBringsYouHere String?
  isVip             Boolean   @default(false)
  otp               String
  otpExpiry         DateTime
  otpCreatedAt      DateTime
  otpSendCount      Int       @default(0)
  otpWindowStart    DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model WaitlistUser {
  id                 String    @id @default(cuid())
  email              String    @unique
  firstName          String?
  lastName           String?
  country            String?
  primaryInterest    String?
  whatBringsYouHere  String?
  isVip              Boolean   @default(false)
  founderNumber      Int?
  verified           Boolean   @default(true)
  welcomeEmailSentAt DateTime?
  createdAt          DateTime  @default(now())
}
